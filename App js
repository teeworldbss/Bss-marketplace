// app.js
import { db } from "./firebase.js";
import { collection, addDoc, getDocs } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

// 🔄 Section switching
function showSection(id) {
  document.querySelectorAll("section").forEach(sec => sec.classList.remove("active"));
  const target = document.getElementById(id);
  if (target) target.classList.add("active");
}

// 📝 Register user
async function registerUser(e) {
  e.preventDefault();
  await addDoc(collection(db, "bss_registrations"), {
    name: document.getElementById("rName").value,
    phone: document.getElementById("rPhone").value,
    role: document.getElementById("rRole").value,
    status: "pending",
    created_at: new Date()
  });
  alert("✅ Registration saved.");
  showSection("home");
}

// 🔐 Authenticate user
async function authenticate(e) {
  e.preventDefault();
  const user = document.getElementById("loginUser").value;
  const pass = document.getElementById("loginPass").value;
  if (user === "08118428191" && pass === "mastercode") {
    alert("🔴 Master Node Access Granted");
    showSection("dashboard");
    loadDashboard();
  } else {
    alert("❌ Invalid credentials");
  }
}

// 🛒 Load marketplace listings
async function loadMarketplace() {
  const snapshot = await getDocs(collection(db, "marketplace"));
  const listings = snapshot.docs.map(doc => doc.data());
  document.getElementById("marketListings").innerHTML =
    listings.map(item => `<div class="card">💬 ${item.name} — Vendor: ${item.vendor}</div>`).join("");
}
loadMarketplace();

// 📊 Load dashboard stats
async function loadDashboard() {
  const snapshot = await getDocs(collection(db, "bss_registrations"));
  const users = snapshot.docs.map(doc => doc.data());
  document.getElementById("dashboardStats").innerHTML =
    `<div class="card">Total Registrations: ${users.length}</div>`;
}

// 🤖 AI Assistant placeholder
function askAI() {
  const question = document.getElementById("aiInput").value;
  document.getElementById("aiResponse").innerText =
    `AI Assistant (demo): You asked "${question}".`;
}

// 🔧 Firestore connection test
async function testFirestore() {
  await addDoc(collection(db, "test_collection"), {
    message: "Hello Firebase!",
    created_at: new Date()
  });

  const snapshot = await getDocs(collection(db, "test_collection"));
  snapshot.forEach(doc => {
    console.log("Test doc:", doc.data());
