async function loadMarketplace() {
  const snapshot = await getDocs(collection(db, "marketplace"));
  const listings = snapshot.docs.map(doc => doc.data());
  document.getElementById("marketListings").innerHTML =
    listings.map(item => `<div class="card">💬 ${item.name} — Vendor: ${item.vendor}</div>`).join("");
}
loadMarketplace();

